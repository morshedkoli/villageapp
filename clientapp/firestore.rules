rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /villages/{villageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Legacy citizen profiles used by older admin panels.
    // Public read keeps the Citizens screen available without login.
    match /citizens/{citizenId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/notification_reads/{notificationId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(['readAt']) &&
        request.resource.data.readAt is timestamp;
      allow delete: if isOwner(userId);
    }

    match /donations/{donationId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0 &&
        request.resource.data.status == 'Pending' &&
        request.resource.data.keys().hasAll(['transactionId', 'senderNumber', 'paymentMethod']);
      allow update, delete: if isAdmin();
    }

    match /fund_transactions/{transactionId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /problems/{problemId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.reportedBy == request.auth.uid;
      // Allow signed-in users to update only upvotes/downvotes for voting
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes'])
      );
      allow delete: if isAdmin();

      // Votes subcollection - users can manage their own votes (document ID = user UID)
      match /votes/{voterId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn() && voterId == request.auth.uid;
      }
    }

    // Application configuration (e.g., payment methods)
    // Public read so donation info is visible without login.
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
