rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /problem_photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /project_photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
