hoto,\n                      width: double.infinity,\n                      height: 140,\n                      fit: BoxFit.cover,\n                    ),\n            ),\n            Padding(\n              padding: const EdgeInsets.all(12),\n              child: Column(\n                crossAxisAlignment: CrossAxisAlignment.start,\n                children: [\n                  Row(\n                    children: [\n                      Expanded(\n                        child: Text(\n                          item.title,\n                          maxLines: 1,\n                          overflow: TextOverflow.ellipsis,\n                          style: Theme.of(context).textTheme.titleMedium,\n                        ),\n                      ),\n                      StatusBadge(text: item.status),\n                    ],\n                  ),\n                  _vGap(context, 8, 6),\n                  Text('${tr('Location', 'অবস্থান')}: ${item.location}'),\n                  _vGap(context, 6, 4),\n                  Text(\n                    item.description,\n                    maxLines: compact ? 2 : 3,\n                    overflow: TextOverflow.ellipsis,\n                  ),\n                ],\n              ),\n            ),\n          ],\n        ),\n      ),\n    );\n  }\n}\n\nclass ReportProblemScreen extends StatefulWidget {\n  const ReportProblemScreen({super.key});\n\n  @override\n  State<ReportProblemScreen> createState() => _ReportProblemScreenState();\n}\n\nclass _ReportProblemScreenState extends State<ReportProblemScreen> {\n  final _form = GlobalKey<FormState>();\n  final _title = TextEditingController();\n  final _description = TextEditingController();\n  final _location = TextEditingController();\n  File? _photo;\n  bool _submitting = false;\n\n  @override\n  void dispose() {\n    _title.dispose();\n    _description.dispose();\n    _location.dispose();\n    super.dispose();\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(\n        title: Text(tr('Report a Problem', 'সমস্যা রিপোর্ট করুন')),\n        actions: [_menuButton()],\n      ),\n      body: ListView(\n        padding: _pagePadding(context),\n        children: [\n          AppCard(\n            child: Form(\n              key: _form,\n              child: Column(\n                children: [\n                  TextFormField(\n                    controller: _title,\n                    decoration: InputDecoration(\n                      labelText: tr('Title', 'শিরোনাম'),\n                      prefixIcon: Icon(Icons.title),\n                    ),\n                    validator: (v) =>\n                        (v == null || v.trim().isEmpty)\n                        ? tr('Required', 'প্রয়োজনীয়')\n                        : null,\n                  ),\n                  _vGap(context, 12, 8),\n                  TextFormField(\n                    controller: _description,\n                    minLines: 3,\n                    maxLines: 6,\n                    decoration: InputDecoration(\n                      labelText: tr('Description', 'বিবরণ'),\n                      prefixIcon: Icon(Icons.description_outlined),\n                    ),\n                    validator: (v) =>\n                        (v == null || v.trim().isEmpty)\n                        ? tr('Required', 'প্রয়োজনীয়')\n                        : null,\n                  ),\n                  _vGap(context, 12, 8),\n                  TextFormField(\n                    controller: _location,\n                    decoration: InputDecoration(\n                      labelText: tr('Location', 'অবস্থান'),\n                      prefixIcon: Icon(Icons.location_on_outlined),\n                    ),\n                    validator: (v) =>\n                        (v == null || v.trim().isEmpty)\n                        ? tr('Required', 'প্রয়োজনীয়')\n                        : null,\n                  ),\n                  _vGap(context, 12, 8),\n                  OutlinedButton.icon(\n                    onPressed: _pickPhoto,\n                    icon: const Icon(Icons.add_a_photo_outlined),\n                    label: Text(\n                      _photo == null\n                          ? tr('Upload Photo', 'ছবি আপলোড করুন')\n                          : tr('Photo selected', 'ছবি নির্বাচন করা হয়েছে'),\n                    ),\n                  ),\n                  _vGap(context, 16, 12),\n                  FilledButton(\n                    onPressed: _submitting ? null : _submit,\n                    child: Text(\n                      _submitting\n                          ? tr('Submitting...', 'জমা দেওয়া হচ্ছে...')\n                          : tr('Submit Problem Report', 'সমস্যা রিপোর্ট জমা দিন'),\n                    ),\n                  ),\n                ],\n              ),\n            ),\n          ),\n        ],\n      ),\n\n      bottomNavigationBar: _buildBottomTabBar(\n        context,\n        selectedIndex: 3,\n        onSelected: (index) => _openRootTab(context, index),\n      ),\n    );\n  }\n\n  Future<void> _pickPhoto() async {\n    final image = await ImagePicker().pickImage(\n      source: ImageSource.gallery,\n      imageQuality: 75,\n    );\n    if (image == null) {\n      return;\n    }\n    setState(() => _photo = File(image.path));\n  }\n\n  Future<void> _submit() async {\n    if (!(_form.currentState?.validate() ?? false)) {\n      return;\n    }\n    setState(() => _submitting = true);\n    try {\n      await DataService.instance.reportProblem(\n        title: _title.text.trim(),\n        description: _description.text.trim(),\n        location: _location.text.trim(),\n        photo: _photo,\n      );\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(context).showSnackBar(\n        SnackBar(\n          content: Text(\n            tr('Problem reported successfully', 'সমস্যা সফলভাবে রিপোর্ট করা হয়েছে'),\n          ),\n        ),\n      );\n      Navigator.of(context).pop();\n    } catch (e) {\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(\n        context,\n      ).showSnackBar(SnackBar(content: Text('${tr('Error', 'ত্রুটি')}: $e')));\n    } finally {\n      if (mounted) {\n        setState(() => _submitting = false);\n      }\n    }\n  }\n}\n\nclass CitizensPage extends StatelessWidget {\n  const CitizensPage({super.key});\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(title: Text(tr('Citizens', 'নাগরিক')), actions: [_menuButton()]),\n      body: const CitizensScreen(),\n      bottomNavigationBar: _buildBottomTabBar(\n        context,\n        selectedIndex: 0,\n        onSelected: (index) => _openRootTab(context, index),\n      ),\n    );\n  }\n}\n\nclass LeaderboardPage extends StatelessWidget {\n  const LeaderboardPage({super.key});\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(\n        title: Text(tr('Leaderboard', 'লিডারবোর্ড')),\n        actions: [_menuButton()],\n      ),\n      body: const LeaderboardScreen(),\n      bottomNavigationBar: _buildBottomTabBar(\n        context,\n        selectedIndex: 0,\n        onSelected: (index) => _openRootTab(context, index),\n      ),\n    );\n  }\n}\n\nclass CitizensScreen extends StatefulWidget {\n  const CitizensScreen({super.key});\n\n  @override\n  State<CitizensScreen> createState() => _CitizensScreenState();\n}\n\nclass _CitizensScreenState extends State<CitizensScreen> {\n  final _search = TextEditingController();\n\n  Future<void> _refreshCitizens() async {\n    try {\n      await DataService.instance\n          .citizens()\n          .first\n          .timeout(const Duration(seconds: 8));\n    } catch (_) {\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(context).showSnackBar(\n        SnackBar(\n          content: Text(\n            tr(\n              'Unable to fully refresh citizens now.',\n              'এখন নাগরিক তালিকা পুরোপুরি রিফ্রেশ করা যাচ্ছে না।',\n            ),\n          ),\n        ),\n      );\n    }\n    if (mounted) {\n      setState(() {});\n    }\n  }\n\n  @override\n  void dispose() {\n    _search.dispose();\n    super.dispose();\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    return StreamBuilder<List<Citizen>>(\n      stream: DataService.instance.citizens(),\n      builder: (context, snap) {\n        final all = snap.data ?? const <Citizen>[];\n        final q = _search.text.trim().toLowerCase();\n        final filtered = all\n            .where(\n              (c) =>\n                  c.name.toLowerCase().contains(q) ||\n                  c.profession.toLowerCase().contains(q),\n            )\n            .toList();\n\n        return RefreshIndicator(\n          onRefresh: _refreshCitizens,\n          color: const Color(0xFF1F7A5A),\n          child: ListView(\n            physics: const AlwaysScrollableScrollPhysics(\n              parent: BouncingScrollPhysics(),\n            ),\n            padding: _pagePadding(context),\n            children: [\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 40),\n                offset: const Offset(0, 0.03),\n                child: _CitizensHero(total: all.length),\n              ),\n              _vGap(context, 14, 10),\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 120),\n                offset: const Offset(0, 0.03),\n                child: _HomeSectionShell(\n                  title: tr('Citizen Directory', 'নাগরিক ডিরেক্টরি'),\n                  subtitle: tr(\n                    'Find villagers by name and profession',\n                    'নাম ও পেশা দিয়ে নাগরিক খুঁজুন',\n                  ),\n                  child: Column(\n                    children: [\n                      TextField(\n                        controller: _search,\n                        onChanged: (_) => setState(() {}),\n                        decoration: InputDecoration(\n                          hintText: tr(\n                            'Search name or profession',\n                            'নাম বা পেশা লিখে খুঁজুন',\n                          ),\n                          prefixIcon: Icon(Icons.search),\n                        ),\n                      ),\n                      _vGap(context, 10, 7),\n                      if (snap.connectionState == ConnectionState.waiting)\n                        const Column(\n                          children: [\n                            SkeletonCard(height: 70),\n                            SkeletonCard(height: 70),\n                          ],\n                        )\n                      else if (filtered.isEmpty)\n                        EmptyStateCard(\n                          icon: Icons.search_off,\n                          title: tr('No matching citizens', 'মিলছে এমন নাগরিক নেই'),\n                          message: tr(\n                            'Try a different name or profession keyword.',\n                            'অন্য নাম বা পেশার কীওয়ার্ড চেষ্টা করুন।',\n                          ),\n                        )\n                      else\n                        ...filtered.asMap().entries.map((entry) {\n                          final c = entry.value;\n                          return AnimatedEntry(\n                            delay: Duration(milliseconds: 35 * entry.key),\n                            child: AppCard(\n                              child: Row(\n                                children: [\n                                  CircleAvatar(\n                                    radius: 23,\n                                    backgroundColor: const Color(\n                                      0xFF4A90E2,\n                                    ).withValues(alpha: 0.14),\n                                    child: Text(\n                                      c.name.isEmpty\n                                          ? '?'\n                                          : c.name.substring(0, 1).toUpperCase(),\n                                      style: const TextStyle(\n                                        color: Color(0xFF4A90E2),\n                                        fontWeight: FontWeight.w700,\n                                      ),\n                                    ),\n                                  ),\n                                  const SizedBox(width: 12),\n                                  Expanded(\n                                    child: Column(\n                                      crossAxisAlignment:\n                                          CrossAxisAlignment.start,\n                                      children: [\n                                        Text(\n                                          c.name,\n                                          style: Theme.of(\n                                            context,\n                                          ).textTheme.titleMedium,\n                                        ),\n                                        Text(c.profession),\n                                      ],\n                                    ),\n                                  ),\n                                ],\n                              ),\n                            ),\n                          );\n                        }),\n                    ],\n                  ),\n                ),\n              ),\n            ],\n          ),\n        );\n      },\n    );\n  }\n}\n\nclass LeaderboardScreen extends StatefulWidget {\n  const LeaderboardScreen({super.key});\n\n  @override\n  State<LeaderboardScreen> createState() => _LeaderboardScreenState();\n}\n\nclass _LeaderboardScreenState extends State<LeaderboardScreen> {\n  bool _monthly = false;\n\n  Future<void> _refreshLeaderboard() async {\n    try {\n      await DataService.instance\n          .donations(limit: 500)\n          .first\n          .timeout(const Duration(seconds: 8));\n    } catch (_) {\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(context).showSnackBar(\n        SnackBar(\n          content: Text(\n            tr(\n              'Unable to fully refresh leaderboard now.',\n              'এখন লিডারবোর্ড পুরোপুরি রিফ্রেশ করা যাচ্ছে না।',\n            ),\n          ),\n        ),\n      );\n    }\n    if (mounted) {\n      setState(() {});\n    }\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    return StreamBuilder<List<Donation>>(\n      stream: DataService.instance.donations(limit: 500),\n      builder: (context, snap) {\n        var donations = snap.data ?? const <Donation>[];\n        if (_monthly) {\n          final now = DateTime.now();\n          donations = donations\n              .where(\n                (d) =>\n                    d.createdAt.year == now.year && d.createdAt.month == now.month,\n              )\n              .toList();\n        }\n\n        final totals = <String, double>{};\n        for (final d in donations) {\n          totals[d.donorName] = (totals[d.donorName] ?? 0) + d.amount;\n        }\n\n        final ranking = totals.entries.toList()\n          ..sort((a, b) => b.value.compareTo(a.value));\n        final totalRaised = donations.fold<double>(0, (sum, d) => sum + d.amount);\n\n        return RefreshIndicator(\n          onRefresh: _refreshLeaderboard,\n          color: const Color(0xFF1F7A5A),\n          child: ListView(\n            physics: const AlwaysScrollableScrollPhysics(\n              parent: BouncingScrollPhysics(),\n            ),\n            padding: _pagePadding(context),\n            children: [\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 40),\n                offset: const Offset(0, 0.03),\n                child: _LeaderboardHero(\n                  donorCount: ranking.length,\n                  totalRaised: totalRaised,\n                  monthly: _monthly,\n                ),\n              ),\n              _vGap(context, 14, 10),\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 120),\n                offset: const Offset(0, 0.03),\n                child: _HomeSectionShell(\n                  title: tr('Donation Ranking', 'অনুদান র‌্যাংকিং'),\n                  subtitle: tr(\n                    'See top contributors by total donated amount',\n                    'মোট অনুদানের ভিত্তিতে শীর্ষ অবদানকারীদের দেখুন',\n                  ),\n                  child: Column(\n                    children: [\n                      SegmentedButton<bool>(\n                        showSelectedIcon: false,\n                        selected: {_monthly},\n                        onSelectionChanged: (v) => setState(() => _monthly = v.first),\n                        segments: [\n                          ButtonSegment(\n                            value: false,\n                            label: Text(tr('All Time', 'সর্বমোট')),\n                          ),\n                          ButtonSegment(\n                            value: true,\n                            label: Text(tr('Monthly', 'মাসিক')),\n                          ),\n                        ],\n                      ),\n                      _vGap(context, 10, 7),\n                      if (snap.connectionState == ConnectionState.waiting)\n                        const Column(\n                          children: [\n                            SkeletonCard(height: 110),\n                            SkeletonCard(height: 110),\n                          ],\n                        )\n                      else if (ranking.isEmpty)\n                        EmptyStateCard(\n                          icon: Icons.leaderboard_outlined,\n                          title: tr('No leaderboard data', 'লিডারবোর্ড ডেটা নেই'),\n                          message: tr(\n                            'Donor ranking will appear when donations are made.',\n                            'অনুদান এলে দাতার র‌্যাংকিং এখানে দেখাবে।',\n                          ),\n                        )\n                      else ...[\n                        _TopThreeDonors(entries: ranking.take(3).toList()),\n                        _vGap(context, 12, 8),\n                        ...ranking.asMap().entries.map((entry) {\n                          final rank = entry.key + 1;\n                          return AnimatedEntry(\n                            delay: Duration(milliseconds: 35 * rank),\n                            child: _LeaderboardRankTile(\n                              rank: rank,\n                              donor: entry.value.key,\n                              amount: entry.value.value,\n                            ),\n                          );\n                        }),\n                      ],\n                    ],\n                  ),\n                ),\n              ),\n            ],\n          ),\n        );\n      },\n    );\n  }\n}\n\nclass ProfileScreen extends StatelessWidget {\n  const ProfileScreen({super.key});\n\n  @override\n  Widget build(BuildContext context) {\n    final data = DataService.instance;\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(title: Text(tr('Profile', 'প্রোফাইল')), actions: [_menuButton()]),\n      body: StreamBuilder(\n        stream: data.authState(),\n        builder: (context, _) {\n          final user = data.currentUser;\n          if (user == null) {\n            return Center(\n              child: Padding(\n                padding: const EdgeInsets.all(20),\n                child: FilledButton(\n                  onPressed: () {\n                    Navigator.of(context).push(\n                      MaterialPageRoute(builder: (_) => const LoginScreen()),\n                    );\n                  },\n                  child: Text(tr('Login with Email OTP', 'ইমেইল OTP দিয়ে লগইন')),\n                ),\n              ),\n            );\n          }\n\n          return ListView(\n            padding: _pagePadding(context),\n            children: [\n              AppCard(\n                child: Row(\n                  children: [\n                    CircleAvatar(\n                      radius: 26,\n                      backgroundColor: const Color(\n                        0xFF1F7A5A,\n                      ).withValues(alpha: 0.12),\n                      child: const Icon(Icons.person, color: Color(0xFF1F7A5A)),\n                    ),\n                    const SizedBox(width: 12),\n                    Expanded(\n                      child: Column(\n                        crossAxisAlignment: CrossAxisAlignment.start,\n                        children: [\n                          Text(\n                            user.email?.split('@').first ?? 'Citizen',\n                            style: Theme.of(context).textTheme.titleMedium,\n                          ),\n                          Text(user.email ?? ''),\n                        ],\n                      ),\n                    ),\n                    TextButton(\n                      onPressed: data.signOut,\n                      child: Text(tr('Logout', 'লগআউট')),\n                    ),\n                  ],\n                ),\n              ),\n              _vGap(context, 12, 8),\n              ValueListenableBuilder<AccessibilitySettings>(\n                valueListenable: accessibilityController,\n                builder: (context, settings, _) {\n                  return AppCard(\n                    child: Column(\n                      children: [\n                        SwitchListTile(\n                          contentPadding: EdgeInsets.zero,\n                          title: Text(tr('Large text mode', 'বড় লেখা মোড')),\n                          subtitle: Text(\n                            tr(\n                              'Improves readability for older users',\n                              'বয়স্ক ব্যবহারকারীর পড়া সহজ করে',\n                            ),\n                          ),\n                          value: settings.largeText,\n                          onChanged: accessibilityController.setLargeText,\n                        ),\n                        const Divider(height: 8),\n                        SwitchListTile(\n                          contentPadding: EdgeInsets.zero,\n                          title: Text(tr('High contrast mode', 'উচ্চ কনট্রাস্ট মোড')),\n                          subtitle: Text(\n                            tr(\n                              'Enhances text and color contrast',\n                              'লেখা ও রঙের কনট্রাস্ট বাড়ায়',\n                            ),\n                          ),\n                          value: settings.highContrast,\n                          onChanged: accessibilityController.setHighContrast,\n                        ),\n                        const Divider(height: 8),\n                        ListTile(\n                          contentPadding: EdgeInsets.zero,\n                          title: Text(tr('Language', 'ভাষা')),\n                          subtitle: Text(\n                            tr(\n                              'Choose app language',\n                              'অ্যাপের ভাষা নির্বাচন করুন',\n                            ),\n                          ),\n                          trailing: SegmentedButton<String>(\n                            showSelectedIcon: false,\n                            selected: {settings.languageCode},\n                            onSelectionChanged: (value) =>\n                                accessibilityController.setLanguageCode(\n                                  value.first,\n                                ),\n                            segments: [\n                              ButtonSegment(\n                                value: 'en',\n                                label: Text(tr('English', 'ইংরেজি')),\n                              ),\n                              ButtonSegment(\n                                value: 'bn',\n                                label: Text(tr('Bangla', 'বাংলা')),\n                              ),\n                            ],\n                          ),\n                        ),\n                      ],\n                    ),\n                  );\n                },\n              ),\n              _vGap(context, 14, 10),\n              SectionTitle(title: tr('Donation History', 'অনুদানের ইতিহাস')),\n              _vGap(context, 8, 6),\n              StreamBuilder<List<Donation>>(\n                stream: data.myDonations(),\n                builder: (context, snap) {\n                  final list = snap.data ?? const <Donation>[];\n                  final total = list.fold<double>(\n                    0,\n                    (sum, d) => sum + d.amount,\n                  );\n                  return Column(\n                    children: [\n                      AppCard(\n                        child: Row(\n                          children: [\n                            Expanded(child: Text(tr('Total Donated', 'মোট অনুদান'))),\n                            Text(\n                              currency.format(total),\n                              style: const TextStyle(\n                                fontWeight: FontWeight.w700,\n                              ),\n                            ),\n                          ],\n                        ),\n                      ),\n                      ...list.asMap().entries.map(\n                        (entry) => AnimatedEntry(\n                          delay: Duration(milliseconds: 40 * entry.key),\n                          child: DonationCard(item: entry.value),\n                        ),\n                      ),\n                    ],\n                  );\n                },\n              ),\n              _vGap(context, 14, 10),\n              SectionTitle(title: tr('Reported Problems', 'রিপোর্ট করা সমস্যা')),\n              _vGap(context, 8, 6),\n              StreamBuilder<List<ProblemReport>>(\n                stream: data.myProblems(),\n                builder: (context, snap) {\n                  final list = snap.data ?? const <ProblemReport>[];\n                  if (list.isEmpty) {\n                    return EmptyStateCard(\n                      icon: Icons.report_problem_outlined,\n                      title: tr('No reported problems', 'কোনো সমস্যা রিপোর্ট নেই'),\n                      message: tr(\n                        'Your submitted issues will appear in this section.',\n                        'আপনার জমা দেওয়া সমস্যাগুলো এখানে দেখাবে।',\n                      ),\n                    );\n                  }\n                  return Column(\n                    children: list\n                        .asMap()\n                        .entries\n                        .map(\n                          (entry) => AnimatedEntry(\n                            delay: Duration(milliseconds: 40 * entry.key),\n                            child: ProblemViewCard(item: entry.value),\n                          ),\n                        )\n                        .toList(),\n                  );\n                },\n              ),\n            ],\n          );\n        },\n      ),\n    );\n  }\n}\n\nclass LoginScreen extends StatefulWidget {\n  const LoginScreen({super.key});\n\n  @override\n  State<LoginScreen> createState() => _LoginScreenState();\n}\n\nclass _LoginScreenState extends State<LoginScreen> {\n  final _email = TextEditingController();\n  final _link = TextEditingController();\n  bool _loading = false;\n\n  @override\n  void dispose() {\n    _email.dispose();\n    _link.dispose();\n    super.dispose();\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(\n        title: Text(tr('Email OTP Login', 'ইমেইল OTP লগইন')),\n        actions: [_menuButton()],\n      ),\n      body: ListView(\n        padding: _pagePadding(context),\n        children: [\n          const AppCard(\n            child: Text(\n              'Viewing data is public. Login is required only for donation and reporting problems.',\n            ),\n          ),\n          _vGap(context, 10, 7),\n          TextField(\n            controller: _email,\n            keyboardType: TextInputType.emailAddress,\n            decoration: InputDecoration(\n              labelText: tr('Email address', 'ইমেইল ঠিকানা'),\n              prefixIcon: Icon(Icons.email_outlined),\n            ),\n          ),\n          _vGap(context, 10, 7),\n          FilledButton(\n            onPressed: _loading ? null : _sendLink,\n            child: Text(\n              _loading\n                  ? tr('Sending...', 'পাঠানো হচ্ছে...')\n                  : tr('Send OTP Link', 'OTP লিংক পাঠান'),\n            ),\n          ),\n          _vGap(context, 14, 10),\n          TextField(\n            controller: _link,\n            minLines: 2,\n            maxLines: 4,\n            decoration: InputDecoration(\n              labelText: tr('Paste received email link', 'প্রাপ্ত ইমেইল লিংক পেস্ট করুন'),\n              prefixIcon: Icon(Icons.link),\n            ),\n          ),\n          _vGap(context, 10, 7),\n          OutlinedButton(\n            onPressed: _loading ? null : _verify,\n            child: Text(\n              _loading\n                  ? tr('Verifying...', 'যাচাই করা হচ্ছে...')\n                  : tr('Verify & Login', 'যাচাই করে লগইন'),\n            ),\n          ),\n        ],\n      ),\n\n      bottomNavigationBar: _buildBottomTabBar(\n        context,\n        selectedIndex: 0,\n        onSelected: (index) => _openRootTab(context, index),\n      ),\n    );\n  }\n\n  Future<void> _sendLink() async {\n    final email = _email.text.trim();\n    if (!email.contains('@')) {\n      ScaffoldMessenger.of(context).showSnackBar(\n        SnackBar(content: Text(tr('Enter a valid email address', 'সঠিক ইমেইল ঠিকানা দিন'))),\n      );\n      return;\n    }\n    setState(() => _loading = true);\n    try {\n      await DataService.instance.sendLoginLink(email);\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(context).showSnackBar(\n        SnackBar(\n          content: Text(\n            tr(\n              'Email OTP link sent. Check your inbox.',\n              'ইমেইল OTP লিংক পাঠানো হয়েছে। ইনবক্স দেখুন।',\n            ),\n          ),\n        ),\n      );\n    } catch (e) {\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(\n        context,\n      ).showSnackBar(SnackBar(content: Text('${tr('Error', 'ত্রুটি')}: $e')));\n    } finally {\n      if (mounted) {\n        setState(() => _loading = false);\n      }\n    }\n  }\n\n  Future<void> _verify() async {\n    setState(() => _loading = true);\n    try {\n      await DataService.instance.signInWithEmailLink(\n        email: _email.text.trim(),\n        emailLink: _link.text.trim(),\n      );\n      if (!mounted) {\n        return;\n      }\n      Navigator.of(context).pop();\n    } catch (e) {\n      if (!mounted) {\n        return;\n      }\n      ScaffoldMessenger.of(\n        context,\n      ).showSnackBar(SnackBar(content: Text('${tr('Error', 'ত্রুটি')}: $e')));\n    } finally {\n      if (mounted) {\n        setState(() => _loading = false);\n      }\n    }\n  }\n}\n\nclass NotificationScreen extends StatefulWidget {\n  const NotificationScreen({super.key});\n\n  @override\n  State<NotificationScreen> createState() => _NotificationScreenState();\n}\n\nclass _NotificationScreenState extends State<NotificationScreen> {\n  String _filter = 'All';\n\n  IconData _iconFor(String type) {\n    switch (type) {\n      case 'donation':\n        return Ico