দেখাবে।',\n                          ),\n                        )\n                      : Column(\n                          children: items\n                              .asMap()\n                              .entries\n                              .map(\n                                (entry) => AnimatedEntry(\n                                  delay: Duration(milliseconds: 45 * entry.key),\n                                  child: ProjectCard(\n                                    item: entry.value,\n                                    onTap: () {\n                                      Navigator.of(context).push(\n                                        MaterialPageRoute(\n                                          builder: (_) => ProjectDetailScreen(\n                                            project: entry.value,\n                                          ),\n                                        ),\n                                      );\n                                    },\n                                  ),\n                                ),\n                              )\n                              .toList(),\n                        ),\n                ),\n              ),\n            ],\n          ),\n        );\n      },\n    );\n  }\n}\n\nclass ProjectDetailScreen extends StatelessWidget {\n  const ProjectDetailScreen({super.key, required this.project});\n\n  final DevelopmentProject project;\n\n  @override\n  Widget build(BuildContext context) {\n    final cover = project.photos.isNotEmpty ? project.photos.first : '';\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(title: Text(project.title), actions: [_menuButton()]),\n      body: ListView(\n        children: [\n          SizedBox(\n            height: 220,\n            child: cover.isNotEmpty\n                ? Image.network(cover, fit: BoxFit.cover)\n                : Container(\n                    decoration: const BoxDecoration(\n                      gradient: LinearGradient(\n                        colors: [Color(0xFF1F7A5A), Color(0xFF4A90E2)],\n                        begin: Alignment.topLeft,\n                        end: Alignment.bottomRight,\n                      ),\n                    ),\n                    child: const Center(\n                      child: Icon(\n                        Icons.landscape,\n                        size: 54,\n                        color: Colors.white70,\n                      ),\n                    ),\n                  ),\n          ),\n          Padding(\n            padding: _pagePadding(context),\n            child: Column(\n              crossAxisAlignment: CrossAxisAlignment.start,\n              children: [\n                ProjectCard(item: project),\n                _vGap(context, 12, 8),\n                AppCard(child: Text(project.description)),\n                _vGap(context, 16, 12),\n                SectionTitle(title: tr('Progress Timeline', 'অগ্রগতির টাইমলাইন')),\n                _vGap(context, 10, 7),\n                if (project.updates.isEmpty)\n                  EmptyStateCard(\n                    icon: Icons.timeline_outlined,\n                    title: tr('No updates yet', 'এখনও কোনো আপডেট নেই'),\n                    message: tr(\n                      'Progress updates will be added by project admins.',\n                      'প্রকল্প অ্যাডমিনরা অগ্রগতির আপডেট যোগ করবেন।',\n                    ),\n                  )\n                else\n                  ...project.updates.asMap().entries.map(\n                    (entry) => AnimatedEntry(\n                      delay: Duration(milliseconds: 40 * entry.key),\n                      child: AppCard(\n                        child: Row(\n                          children: [\n                            const Icon(\n                              Icons.check_circle_outline,\n                              color: Color(0xFF4A90E2),\n                            ),\n                 