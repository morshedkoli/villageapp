alueChanged<int> onSelected,\n}) {\n  final media = MediaQuery.of(context);\n  final compact = media.size.width < 390 || media.textScaler.scale(1.0) > 1.15;\n  final horizontal = compact ? 8.0 : 12.0;\n  final bottom = compact ? 8.0 : 10.0;\n\n  return SafeArea(\n    child: Padding(\n      padding: EdgeInsets.fromLTRB(horizontal, 0, horizontal, bottom),\n      child: Container(\n        decoration: BoxDecoration(\n          gradient: const LinearGradient(\n            colors: [Color(0xFFFFFFFF), Color(0xFFF3F9F6)],\n            begin: Alignment.topCenter,\n            end: Alignment.bottomCenter,\n          ),\n          borderRadius: BorderRadius.circular(22),\n          border: Border.all(color: const Color(0xFFE2EBEF)),\n          boxShadow: const [\n            BoxShadow(\n              color: Color(0x140A2433),\n              blurRadius: 20,\n              offset: Offset(0, 6),\n            ),\n          ],\n        ),\n        child: ClipRRect(\n          borderRadius: BorderRadius.circular(22),\n          child: NavigationBar(\n            selectedIndex: selectedIndex,\n            onDestinationSelected: onSelected,\n            destinations: _rootDestinations(),\n          ),\n        ),\n      ),\n    ),\n  );\n}\n\nclass RootShell extends StatefulWidget {\n  const RootShell({super.key, this.initialIndex = 0});\n\n  final int initialIndex;\n\n  @override\n  State<RootShell> createState() => _RootShellState();\n}\n\nclass _RootShellState extends State<RootShell>\n    with SingleTickerProviderStateMixin {\n  late int _index;\n  late final AnimationController _fabPulse;\n\n  @override\n  void initState() {\n    super.initState();\n    _index = widget.initialIndex.clamp(0, 3);\n    _fabPulse = AnimationController(\n      vsync: this,\n      duration: const Duration(milliseconds: 1500),\n    )..repeat(reverse: true);\n  }\n\n  @override\n  void dispose() {\n    _fabPulse.dispose();\n    super.dispose();\n  }\n\n  final List<Widget> _screens = const [\n    HomeSc