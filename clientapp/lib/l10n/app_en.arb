                   );\n                    },\n                    child: Text(tr('View all', 'সব দেখুন')),\n                  ),\n                  child: StreamBuilder<List<Donation>>(\n                    stream: data.donations(limit: 8),\n                    builder: (context, snap) {\n                      if (snap.hasError) {\n                        return Text(\n                          '${tr('Failed to load donations', 'অনুদান লোড করা যায়নি')}: ${snap.error}',\n                        );\n                      }\n                      if (snap.connectionState == ConnectionState.waiting) {\n                        return const _HorizontalSkeleton();\n                      }\n                      final items = snap.data ?? const <Donation>[];\n                      return _HorizontalDonationList(items: items);\n                    },\n                  ),\n                ),\n              ),\n              _vGap(context, 14, 10),\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 320),\n                offset: const Offset(0, 0.035),\n                child: _HomeSectionShell(\n                  title: tr('Latest Problems', 'সাম্প্রতিক সমস্যা'),\n                  subtitle: tr(\n                    'Recently submitted community issues',\n                    'সম্প্রতি জমা দেওয়া কমিউনিটির সমস্যা',\n                  ),\n                  child: StreamBuilder<List<ProblemReport>>(\n                    stream: data.problems(limit: 8),\n                    builder: (context, snap) {\n                      if (snap.hasError) {\n                        return Text(\n                          '${tr('Failed to load problems', 'সমস্যা লোড করা যায়নি')}: ${snap.error}',\n                        );\n                      }\n                      if (snap.connectionState == ConnectionState.waiting) {\n                        return const _HorizontalSkeleton();\n                      }\n                      final items = snap.data ?? const <ProblemReport>[];\n                      return _HorizontalProblemList(items: items);\n                    },\n                  ),\n                ),\n              ),\n              _vGap(context, 14, 10),\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 400),\n                offset: const Offset(0, 0.035),\n                child: _HomeSectionShell(\n                  title: tr('Active Projects', 'চলমান প্রকল্প'),\n                  subtitle: tr(\n                    'Progress from ongoing development work',\n                    'চলমান উন্নয়ন কাজের অগ্রগতি',\n                  ),\n                  child: StreamBuilder<List<DevelopmentProject>>(\n                    stream: data.projects(limit: 8),\n                    builder: (context, snap) {\n                      if (snap.hasError) {\n                        return Text(\n                          '${tr('Failed to load projects', 'প্রকল্প লোড করা যায়নি')}: ${snap.error}',\n                        );\n                      }\n                      if (snap.connectionState == ConnectionState.waiting) {\n                        return const _HorizontalSkeleton();\n                      }\n                      final projects =\n                          (snap.data ?? const <DevelopmentProject>[])\n                              .where((p) => p.status != 'Completed')\n                              .toList();\n                      return _HorizontalProjectList(items: projects);\n                    },\n                  ),\n                ),\n              ),\n            ],\n          ),\n        );\n      },\n    );\n  }\n}\n\nclass VillageFundScreen extends StatelessWidget {\n  const VillageFundScreen({super.key, this.showDonate = true});\n\n  final bool showDonate;\n\n  @override\n  Widget build(BuildContext context) {\n    final data = DataService.instance;\n    return StreamBuilder<VillageOverview>(\n      stream: data.villageOverview(),\n      builder: (context, snap) {\n        if (snap.hasError) {\n          return Center(\n            child: Text(\n              '${tr('Failed to load overview', 'ওভারভিউ লোড করা যায়নি')}: ${snap.error}',\n            ),\n          );\n        }\n        final overview =\n            snap.data ??\n            const VillageOverview(\n              name: 'Our Village',\n              totalCitizens: 0,\n              totalFundCollected: 0,\n              totalSpent: 0,\n            );\n\n        return ListView(\n          padding: _pagePadding(context),\n          children: [\n            AnimatedEntry(\n              delay: const Duration(milliseconds: 40),\n              offset: const Offset(0, 0.03),\n              child: _FundHero(overview: overview),\n            ),\n            if (showDonate) ...[\n              _vGap(context, 12, 8),\n              AnimatedEntry(\n                delay: const Duration(milliseconds: 110),\n                offset: const Offset(0, 0.03),\n              child: AppCard(\n                child: Row(\n                  children: [\n                    const Icon(\n                      Icons.volunteer_activism_outlined,\n                      color: Color(0xFF1F7A5A),\n                    ),\n                    const SizedBox(width: 10),\n                    Expanded(\n                      child: Column(\n                        crossAxisAlignment: CrossAxisAlignment.start,\n                        children: [\n                          Text(\n                            'Support today\\'s priorities',\n                            style: Theme.of(context).textTheme.titleMedium,\n                          ),\n                          _vGap(context, 2, 2),\n                          Text(\n                            'Contribute directly to current village initiatives.',\n                            style: Theme.of(context).textTheme.bodySmall,\n                          ),\n                          _vGap(context, 8, 6),\n                          Align(\n     