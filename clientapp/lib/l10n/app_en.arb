               }\n                    return _FundGrowthChart(\n                      donations: donationSnap.data ?? const [],\n                    );\n                  },\n                ),\n              ),\n            ),\n            _vGap(context, 14, 10),\n            AnimatedEntry(\n              delay: const Duration(milliseconds: 260),\n              offset: const Offset(0, 0.03),\n              child: _HomeSectionShell(\n                title: tr('Donation Timeline', 'অনুদানের টাইমলাইন'),\n                subtitle: tr(\n                  'Most recent contributions from community members',\n                  'কমিউনিটির সদস্যদের সাম্প্রতিক অনুদান',\n                ),\n                child: StreamBuilder<List<Donation>>(\n                  stream: data.donations(limit: 80),\n                  builder: (context, donationSnap) {\n                    if (donationSnap.hasError) {\n                      return Text(\n                        'Failed to load donation timeline: \\\\${donationSnap.error}',\n                      );\n                    }\n                    if (donationSnap.connectionState == ConnectionState.waiting) {\n                      return const SkeletonCard();\n                    }\n                    final items = donationSnap.data ?? const <Donation>[];\n                    if (items.isEmpty) {\n                      return EmptyStateCard(\n                        icon: Icons.volunteer_activism_outlined,\n                        title: tr('No donations yet', 'এখনও কোনো অনুদান নেই'),\n                        message: tr(\n                          'Be the first citizen to support the village fund.',\n                          'গ্রাম তহবিল সমর্থনে প্রথম নাগরিক হন।',\n                        ),\n                      );\n                    }\n                    return Column(\n                      children: items\n                          .asMap()\n                          .entries\n                          .map(\n                            (entry) => AnimatedEntry(\n                              delay: Duration(milliseconds: 45 * entry.key),\n                              child: DonationCard(item: entry.value),\n                            ),\n                          )\n                          .toList(),\n                    );\n                  },\n                ),\n              ),\n            ),\n          ],\n        );\n      },\n    );\n  }\n}\n\nclass DonateScreen extends StatefulWidget {\n  const DonateScreen({super.key});\n\n  @override\n  State<DonateScreen> createState() => _DonateScreenState();\n}\n\nclass _DonateScreenState extends State<DonateScreen> {\n  final _form = GlobalKey<FormState>();\n  final _amount = TextEditingController();\n  String _method = 'bKash';\n  bool _submitting = false;\n\n  @override\n  void dispose() {\n    _amount.dispose();\n    super.dispose();\n  }\n\n  @override\n  Widget build(BuildContext context) {\n    return Scaffold(\n      drawer: _buildSidebarMenu(context),\n      appBar: AppBar(\n        title: Text(tr('Donate to Fund', 'তহবিলে অনুদান')),\n        actions: [_menuButton()],\n      ),\n      body: ListView(\n        padding: _pagePadding(context),\n        children: [\n          AppCard(\n            child: Form(\n              key: _form,\n              child: Column(\n                crossAxisAlignment: CrossAxisAlignment.start,\n                children: [\n                  Text(\n                    'Make a Donation',\n                    style: Theme.of(context).textTheme.titleLarge,\n                  ),\n                  _vGap(context, 12, 8),\n                  TextFormField(\n                    controller: _amount,\n                    keyboardType: const TextInputType.numberWithOptions(\n                      decimal: true,\n                    ),\n                    decoration: InputDecoration(\n                      labelText: tr('Donation Amount', 'অনুদানের পরিমাণ'),\n                      prefixIcon: Icon(Icons.currency_exchange),\n                      prefixText: '৳ ',\n                    ),\n                    validator: (value) {\n                      final amount = double.tryParse((value ?? '').trim());\n                      if (amount == null || amount <= 0) {\n                        return tr(\n                          'Enter a valid donation amount',\n                          'সঠিক অনুদানের পরিমাণ লিখুন',\n                        );\n                      }\n                      return null;\n                    },\n                  ),\n                  _vGap(context, 12, 8),\n                  DropdownButtonFormField<String>(\n                    initialValue: _method,\n                    decoration: InputDecoration(\n                      labelText: tr('Payment Method', 'পেমেন্ট পদ্ধতি'),\n                      prefixIcon: Icon(Icons.account_balance_wallet_outlined),\n                    ),\n                    items: [\n                      DropdownMenuItem(value: 'bKash', child: Text('bKash')),\n                      DropdownMenuItem(value: 'Nagad', child: Text('Nagad')),\n                      DropdownMenuItem(value: 'Rocket', child: Text('Rocket')),\n                      DropdownMenuItem(\n                        value: 'Manual Transfer',\n                        child: Text(tr('Manual Transfer', 'ম্যানুয়াল ট্রান্সফার')),\n                      ),\n                    ],\n                    onChanged: (value) =>\n                        setState(() => _method = value ?? 'bKash'),\n                  ),\n                  _vGap(context, 16, 12),\n                  FilledButton(\n                    onPressed: _submitting ? null : _submit,\n                     child: Text(\n                       _submitting\n                           ? tr('Processing...', 'প্রসেস করা হচ্ছে...')\n                           : tr('Confirm Donation', 'অনুদান নিশ্চিত করুন'),\n                     ),\n                   ),\n                ],\n              ),\n      