l(\n                  title: tr('Issue Board', 'সমস্যা বোর্ড'),\n                  subtitle: tr(\n                    'Filter and review community-reported problems',\n                    'ফিল্টার করে কমিউনিটির রিপোর্ট করা সমস্যা দেখুন',\n                  ),\n                  child: Column(\n                    children: [\n                      SingleChildScrollView(\n                        scrollDirection: Axis.horizontal,\n                        child: Row(\n                          children: _filters\n                              .map(\n                                (f) => Padding(\n                                  padding: const EdgeInsets.only(right: 8),\n                                  child: ChoiceChip(\n                                  label: Text(\n                                    f == 'All'\n                                        ? tr('All', 'সব')\n                                        : f == 'Pending'\n                                        ? tr('Pending', 'মুলতুবি')\n                                        : f == 'Approved'\n                                        ? tr('Approved', 'অনুমোদিত')\n                                        : tr('Completed', 'সম্পন্ন'),\n                                  ),\n                                    selected: _filter == f,\n                                    onSelected: (_) =>\n                                        setState(() => _filter = f),\n                                  ),\n                                ),\n                              )\n                              .toList(),\n                        ),\n                      ),\n                      _vGap(context, 10, 7),\n                      if (snap.connectionState == ConnectionState.waiting)\n                        const Column(\n                          children: [\n                            SkeletonCard(height: 220),\n                            SkeletonCard(height: 220),\n                          ],\n                